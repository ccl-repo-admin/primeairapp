{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DATABASE_URL", "DIRECT_URL", "AUTH_SECRET", "AUTH_URL",
        "NEXT_PUBLIC_TIMECLOCK_URL", "NEXT_PUBLIC_GOOGLE_MAPS_API_KEY",
        "FEATURE_TIMECARDS", "FEATURE_WORK_ORDERS", "FEATURE_CUSTOMER_CRM",
        "FEATURE_REPORTS", "FEATURE_PURCHASE_ORDERS", "FEATURE_ESTIMATES",
        "FEATURE_INVOICING", "FEATURE_DISPATCH", "FEATURE_INVENTORY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "db:push": { "cache": false },
    "db:migrate": { "cache": false },
    "db:seed": { "cache": false },
    "db:generate": { "outputs": ["node_modules/.prisma/**"] },
    "db:studio": { "cache": false, "persistent": true }
  }
}
