# ═══════════════════════════════════════════════════════════════════════════════
# SHARED — set in BOTH Vercel projects (hub + timeclock)
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase → Settings → Database → Connection string
# Use the pooler URL (port 6543, Transaction mode) for DATABASE_URL
# Use the direct URL (port 5432) for DIRECT_URL (Prisma migrations only)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Generate once, use the same value in both projects: openssl rand -base64 32
AUTH_SECRET="replace-me"

# Twilio — SMS OTP login for field workers (leave blank to use dev bypass code 123456)
# Create a Verify Service at console.twilio.com/us1/develop/verify/services
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Cloudflare R2 — REQUIRED for photo uploads in production
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
# Enable public access on the bucket and set R2_PUBLIC_URL to its public URL
R2_ACCOUNT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
R2_BUCKET_NAME="primeair-uploads"
R2_PUBLIC_URL="https://uploads.yourdomain.com"


# ═══════════════════════════════════════════════════════════════════════════════
# HUB ONLY — set in the hub Vercel project (hub.yourdomain.com)
# ═══════════════════════════════════════════════════════════════════════════════

AUTH_URL="https://hub.yourdomain.com"
NEXT_PUBLIC_TIMECLOCK_URL="https://clock.yourdomain.com"


# ═══════════════════════════════════════════════════════════════════════════════
# TIMECLOCK ONLY — set in the timeclock Vercel project (clock.yourdomain.com)
# ═══════════════════════════════════════════════════════════════════════════════

AUTH_URL="https://clock.yourdomain.com"
# Dev only — proxies /uploads/* to hub for local image serving (not needed with R2)
HUB_URL="http://localhost:3000"


# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 1+ — leave blank for now, add when ready
# ═══════════════════════════════════════════════════════════════════════════════

# Upstash Redis — rate limiting, Socket.io, BullMQ
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxx"
REDIS_URL="rediss://default:password@xxxxx.upstash.io:6380"

# Google Maps — dispatch map, geocoding, directions
GOOGLE_MAPS_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Resend — transactional email
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Stripe — subscriptions and payments (Phase 3)
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="your-stripe-publishable-key"

# Sentry — error monitoring (Phase 2+)
SENTRY_DSN="https://xxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx"

# QuickBooks Online — Phase 4
QB_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
QB_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
QB_REDIRECT_URI="https://hub.yourdomain.com/api/integrations/qbo/callback"
