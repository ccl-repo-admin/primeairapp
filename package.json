{
  "name": "primeair-app",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "pnpm --filter @primeair/db db:push",
    "db:migrate": "pnpm --filter @primeair/db db:migrate",
    "db:seed": "pnpm --filter @primeair/db db:seed",
    "db:studio": "pnpm --filter @primeair/db db:studio",
    "db:generate": "pnpm --filter @primeair/db db:generate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.2"
}
